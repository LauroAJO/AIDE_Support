{
  "name": "aide-support",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "worker": "wrangler pages dev dist --d1=DB:aide-db",
    "dev:full": "concurrently \"npm run dev\" \"npm run worker\"",
    "build": "vite build && node scripts/postbuild.mjs",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute aide-db --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute aide-db --remote --file=migrations/0001_initial.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^5.0.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.6",
    "vite-plugin-pwa": "^0.20.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "concurrently": "^9.0.0",
    "workbox-window": "^7.0.0"
  }
}
